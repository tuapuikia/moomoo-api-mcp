# Moomoo API MCP Server Configuration

# Server Port (default: 8000)
PORT=8000

# Trading Credentials
# Required for REAL account access. Use plain text or MD5 hash.
# MOOMOO_TRADE_PASSWORD=123456
# MOOMOO_TRADE_PASSWORD_MD5=your_md5_hash

# Broker Region (e.g., FUTUSG, FUTUINC, FUTUSECURITIES)
MOOMOO_SECURITY_FIRM=FUTUSG

# Risk Management Limits (Multi-currency support: '1000USD,500SGD')
# Daily budget limit (resets every calendar day UTC)
MOOMOO_DAILY_LIMIT=1000USD

# Daily realized loss limit (resets every calendar day UTC)
MOOMOO_DAILY_LOSS=200USD

# Persistent global budget (only replenishes on profitable sells)
GLOBAL_LIMIT=5000USD
